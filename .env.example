# Environment Variables for Gen-Z Restaurant POS
# Copy this file to .env and fill in your actual values

# ============================================
# LOCAL DEVELOPMENT
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/restaurant_pos?schema=public"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# PRODUCTION (Supabase + Vercel)
# ============================================
# Get these from Supabase Dashboard → Settings → Database

# Connection Pooling (for serverless - Vercel)
# DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct Connection (bypass pooler for migrations)
# DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# Production URL (update after first Vercel deployment)
# NEXTAUTH_URL="https://your-app-name.vercel.app"

# ============================================
# SECURITY
# ============================================
# Generate new secret: openssl rand -base64 32
# MUST be different in production!
NEXTAUTH_SECRET="vW8xK3mN9pQ2rT5yU7zA4bC6dE8fG0hJ2kL4mN6pQ8s"

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Tax rate (18% GST in India)
TAX_RATE="0.18"

# UPI ID for QR code payments
# NEXT_PUBLIC_UPI_ID="genzrestaurant@paytm"
